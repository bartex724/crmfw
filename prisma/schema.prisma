generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleCode {
  ADMIN
  WAREHOUSE_STAFF
  OFFICE_STAFF
  GUEST
}

enum EventLifecycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum EventItemStatus {
  TO_PACK
  PACKED
  RETURNED
  LOSS
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique @db.VarChar(320)
  passwordHash   String     @map("password_hash")
  isActive       Boolean    @default(true) @map("is_active")
  roleId         String     @map("role_id") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  disabledAt     DateTime?  @map("disabled_at")
  lastLoginAt    DateTime?  @map("last_login_at")
  role           Role       @relation(fields: [roleId], references: [id], onUpdate: Cascade)
  sessions       Session[]
  auditLogsActor AuditLog[] @relation("AuditActor")
  auditLogsUser  AuditLog[] @relation("AuditTargetUser")
  stockAdjustments StockAdjustment[] @relation("StockAdjustmentActor")

  @@index([roleId], map: "users_role_id_idx")
  @@index([isActive], map: "users_is_active_idx")
  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        RoleCode         @unique
  name        String           @db.VarChar(100)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(120)
  name        String           @db.VarChar(120)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "role_permissions_permission_id_idx")
  @@map("role_permissions")
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash") @db.VarChar(191)
  isActive          Boolean   @default(true) @map("is_active")
  idleExpiresAt     DateTime  @map("idle_expires_at")
  absoluteExpiresAt DateTime  @map("absolute_expires_at")
  lastActivityAt    DateTime  @default(now()) @map("last_activity_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  revokedAt         DateTime? @map("revoked_at")
  ipAddress         String?   @map("ip_address") @db.VarChar(45)
  userAgent         String?   @map("user_agent") @db.VarChar(512)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, isActive], map: "sessions_user_id_is_active_idx")
  @@index([idleExpiresAt], map: "sessions_idle_expires_at_idx")
  @@index([absoluteExpiresAt], map: "sessions_absolute_expires_at_idx")
  @@map("sessions")
}

model AuditLog {
  id           String    @id @default(uuid()) @db.Uuid
  actorUserId  String?   @map("actor_user_id") @db.Uuid
  targetUserId String?   @map("target_user_id") @db.Uuid
  action       String    @db.VarChar(100)
  entityType   String    @map("entity_type") @db.VarChar(100)
  entityId     String?   @map("entity_id") @db.VarChar(120)
  metadata     Json?
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.VarChar(512)
  createdAt    DateTime  @default(now()) @map("created_at")
  actorUser    User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  targetUser   User?     @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([createdAt], map: "audit_logs_created_at_idx")
  @@index([actorUserId], map: "audit_logs_actor_user_id_idx")
  @@index([targetUserId], map: "audit_logs_target_user_id_idx")
  @@map("audit_logs")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(120)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  items       Item[]

  @@map("categories")
}

model Item {
  id           String            @id @default(uuid()) @db.Uuid
  name         String            @db.VarChar(180)
  code         String            @unique @db.VarChar(80)
  quantity     Int               @default(0)
  notes        String?           @db.VarChar(2000)
  categoryId   String            @map("category_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  category     Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  photos       ItemPhoto[]
  adjustments  StockAdjustment[]
  eventItems   EventItem[]
  boxItems     BoxItem[]

  @@index([categoryId], map: "items_category_id_idx")
  @@index([quantity], map: "items_quantity_idx")
  @@map("items")
}

model ItemPhoto {
  id           String   @id @default(uuid()) @db.Uuid
  itemId       String   @map("item_id") @db.Uuid
  relativePath String   @map("relative_path") @db.VarChar(1024)
  mimeType     String   @map("mime_type") @db.VarChar(120)
  sizeBytes    Int      @map("size_bytes")
  position     Int      @default(0)
  isMain       Boolean  @default(false) @map("is_main")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([itemId, position], map: "item_photos_item_id_position_idx")
  @@index([itemId, isMain], map: "item_photos_item_id_is_main_idx")
  @@map("item_photos")
}

model StockAdjustment {
  id             String   @id @default(uuid()) @db.Uuid
  itemId         String   @map("item_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  reason         String   @db.VarChar(1000)
  beforeQuantity Int      @map("before_quantity")
  afterQuantity  Int      @map("after_quantity")
  delta          Int
  createdAt      DateTime @default(now()) @map("created_at")
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actorUser      User?    @relation("StockAdjustmentActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([itemId, createdAt], map: "stock_adjustments_item_id_created_at_idx")
  @@index([actorUserId], map: "stock_adjustments_actor_user_id_idx")
  @@map("stock_adjustments")
}

model Event {
  id              String               @id @default(uuid()) @db.Uuid
  name            String               @db.VarChar(180)
  eventDate       DateTime             @map("event_date")
  location        String               @db.VarChar(180)
  notes           String?              @db.VarChar(2000)
  lifecycleStatus EventLifecycleStatus @default(DRAFT) @map("lifecycle_status")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  items           EventItem[]
  eventBoxes      EventBox[]

  @@index([eventDate], map: "events_event_date_idx")
  @@index([lifecycleStatus], map: "events_lifecycle_status_idx")
  @@map("events")
}

model EventItem {
  id              String          @id @default(uuid()) @db.Uuid
  eventId         String          @map("event_id") @db.Uuid
  itemId          String          @map("item_id") @db.Uuid
  plannedQuantity Int             @map("planned_quantity")
  status          EventItemStatus @default(TO_PACK)
  boxCode         String?         @map("box_code") @db.VarChar(80)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  eventItemBoxes  EventItemBox[]

  @@unique([eventId, itemId], map: "event_items_event_id_item_id_key")
  @@index([eventId, status], map: "event_items_event_id_status_idx")
  @@index([itemId], map: "event_items_item_id_idx")
  @@map("event_items")
}

model Box {
  id             String         @id @default(uuid()) @db.Uuid
  boxCode        String         @unique @map("box_code") @db.VarChar(80)
  name           String         @db.VarChar(120)
  notes          String?        @db.VarChar(2000)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  boxItems       BoxItem[]
  eventBoxes     EventBox[]
  eventItemBoxes EventItemBox[]

  @@map("boxes")
}

model BoxItem {
  boxId     String   @map("box_id") @db.Uuid
  itemId    String   @map("item_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  box       Box      @relation(fields: [boxId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([boxId, itemId])
  @@index([itemId], map: "box_items_item_id_idx")
  @@map("box_items")
}

model EventBox {
  eventId   String   @map("event_id") @db.Uuid
  boxId     String   @map("box_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  box       Box      @relation(fields: [boxId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([eventId, boxId])
  @@index([boxId], map: "event_boxes_box_id_idx")
  @@map("event_boxes")
}

model EventItemBox {
  eventItemId String   @map("event_item_id") @db.Uuid
  boxId       String   @map("box_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  eventItem   EventItem @relation(fields: [eventItemId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  box         Box      @relation(fields: [boxId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([eventItemId, boxId])
  @@index([boxId], map: "event_item_boxes_box_id_idx")
  @@map("event_item_boxes")
}
